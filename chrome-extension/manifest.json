{
  "manifest_version": 3,
  "name": "TOML — Top On My List",
  "version": "1.1.0",
  "description": "Ajoutez n'importe quel article à votre wishlist TOML en un clic depuis n'importe quelle page web.",
  "permissions": ["activeTab", "scripting", "cookies", "storage"],
  "host_permissions": ["https://toml.fr/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Ajouter à ma wishlist TOML"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
